# SentinelX AI - Example Environment Configuration
# Do NOT commit the real .env file. Copy this file to .env and fill in the values.

# Backend (FastAPI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
ALLOWED_ORIGINS=*

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
